# Sao chep file nay thanh .env roi dien gia tri that.
# CANH BAO: .env bi gitignore - KHONG BAO GIO commit. service_role key la BI MAT.

# Token bot Discord (Discord Developer Portal -> Bot -> Reset Token).
DISCORD_TOKEN=

# Supabase (Admin, bo qua RLS): Dashboard -> Project Settings -> API.
# service_role key CHI dung o bot/server, TUYET DOI khong dua vao web.
SUPABASE_URL=https://vlsskdwcfcmyubyrtwhn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Lenh goi Claude CLI (mac dinh 'claude'). Doi neu binary o duong dan khac.
CLAUDE_CMD=claude

# --- Link web trong thong bao (tuy chon) ---
# URL goc cua web da deploy -> bot gan link '<url>/tasks/<id>' vao thong bao tao task
# va thong bao hoan thanh, bam vao la mo dung task.
# De trong = thong bao khong co link (khong loi). Dung URL cong khai, KHONG dung
# localhost: link nay gui cho ca team tren Discord.
WEB_BASE_URL=https://m-plan.easygoing.vn

# --- RAG tai lieu (bge-m3 qua Ollama) ---
# Ollama phai dang chay tren may bot ('ollama serve') va da 'ollama pull bge-m3'.
# De trong = mac dinh http://localhost:11434 + model bge-m3.
OLLAMA_HOST=http://localhost:11434
RAG_EMBED_MODEL=bge-m3

# --- Danh muc Google Drive (skill drive_catalog.py) ---
# Cho phep hoi "tai lieu A nam o dau tren Drive" -> bot tra ten + link.
# Dung CHUNG service account voi Google Sheets MCP (xem GOOGLE_SHEETS_MCP.md Buoc 1-2).
# Pham vi = MOI file duoc share cho service account -> chia se DUNG folder can index cho no.
# GDRIVE_SERVICE_ACCOUNT: de trong = mac dinh keys/service-account-gsheets.json (goc repo).
GDRIVE_SERVICE_ACCOUNT=

# --- Dong bo Notion (tuy chon) ---
# URL cong Notion (Vercel serverless function web/api/notion.ts).
NOTION_GATEWAY_URL=
# Secret dung chung de bot xac thuc voi gateway (gui qua header x-sync-secret).
# PHAI TRUNG voi bien NOTION_SYNC_SECRET dat tren Vercel cua web.
# De trong 2 bien nay -> bot bo qua sync Notion (khong loi).
NOTION_SYNC_SECRET=
