# Web env for the Vite SPA (client-safe — these ship in the browser bundle by design).
# Copy to `.env.local` for local dev, and set the same keys in Vercel → Project Settings → Environment Variables.

# Optional fallback domain restriction, used ONLY while the admin allowlist (config/access,
# managed in the web Cấu hình page) is still empty. Leave blank to allow any account at first.
VITE_ALLOWED_EMAIL_DOMAIN=

# Supabase (migration target) — client-safe. Dashboard → Project Settings → API.
# Project ref: vlsskdwcfcmyubyrtwhn → URL is https://vlsskdwcfcmyubyrtwhn.supabase.co
VITE_SUPABASE_URL=https://vlsskdwcfcmyubyrtwhn.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# SERVER-SIDE env for the Vercel serverless functions (web/api/*).
# These are NOT VITE_ prefixed → they never reach the browser bundle.
# Set them in Vercel → Project Settings → Environment Variables (not needed for local
# `npm run dev` unless you run `vercel dev`).
# ---------------------------------------------------------------------------
# Supabase server-side keys — let /api verify incoming Supabase JWTs (see web/api/_auth.ts).
# CHỈ dùng ANON key. Service-role key KHÔNG BAO GIỜ được đặt ở đây hay trên Vercel: nó
# bypass toàn bộ RLS, và chỉ bot self-host mới được giữ (xem bot/.env.example).
SUPABASE_URL=https://vlsskdwcfcmyubyrtwhn.supabase.co
SUPABASE_ANON_KEY=
# Shared secret the bot uses to call the gateways (must match bot/.env NOTION_SYNC_SECRET).
NOTION_SYNC_SECRET=
# Notion sync (optional) — see README §4.
NOTION_TOKEN=
NOTION_DATABASE_ID=
# Notion property mapping — override when your DB columns differ from the defaults.
# Set a value to '' (empty) to DISABLE that column (e.g. no Priority column).
NOTION_PROP_TITLE=Name
NOTION_PROP_STATUS=Status
NOTION_STATUS_TYPE=status
NOTION_PROP_ASSIGNEE=Assignee
NOTION_ASSIGNEE_TYPE=rich_text
NOTION_PROP_DUE=Due
NOTION_PROP_PRIORITY=Priority
# Ánh xạ giá trị app -> tên lựa chọn bên Notion (JSON). Bỏ trống = dùng mặc định trong
# web/api/_notion.ts (status: Todo/In progress/Review/Done · priority: Low/Medium/High/Urgent).
NOTION_STATUS_MAP=
NOTION_PRIORITY_MAP=
# Project linking: the Notion Projects DB id + the relation column on the Tasks DB.
NOTION_PROJECTS_DB_ID=
NOTION_PROP_PROJECT=Project
# Discord "task done" notification (optional): a webhook URL of the target channel.
# Discord → Channel settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=
