rules_version = '2';

// Security rules for Bot Work Tracker. Keep in sync with DATA_MODEL.md.
// The bot uses a service-account (firebase-admin) which BYPASSES these rules —
// so these protect the web client only. Bot-side permission checks live in code.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads a user's role without failing if the doc is missing.
    function roleOf(uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : 'member';
    }

    function isAdmin() {
      return roleOf(request.auth.uid) == 'admin';
    }

    // --- users ---
    // Anyone signed in reads the team roster. Admins fully manage members
    // (add/edit/delete, incl. Discord/Notion links and roles). A normal member may
    // create their own doc on first sign-in and edit it, but cannot self-promote to admin.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
                    || (isSelf(uid) && request.resource.data.role == 'member');
      allow update: if isAdmin()
                    || (isSelf(uid) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // --- config (e.g. the sign-in allowlist at config/access) ---
    // Any signed-in user may read it (the client checks their own access after auth);
    // only admins may change it.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- sprints ---
    // Everyone signed in reads sprints. Only admins create/modify/delete them.
    match /sprints/{sprintId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- projects ---
    // Everyone signed in reads the project list. Only admins manage projects
    // (incl. the Notion project link used to route task syncs).
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- tasks ---
    // Everyone signed in reads all tasks. Any signed-in member can create a task.
    // Update/delete allowed for admins, the reporter, or the current assignee.
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0;
      allow update: if isSignedIn()
                    && (isAdmin()
                        || resource.data.reporterId == request.auth.uid
                        || resource.data.assigneeId == request.auth.uid
                        || request.resource.data.assigneeId == request.auth.uid);
      allow delete: if isAdmin() || resource.data.reporterId == request.auth.uid;
    }

    // --- notifications ---
    // In-app "task done" notices. You may only read/modify/delete notifications
    // addressed to you. Any signed-in user may create one for a teammate (the
    // person who completes a task writes notices for the related people).
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn()
                    && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.recipientId is string
                    && request.resource.data.recipientId.size() > 0;
    }
  }
}
